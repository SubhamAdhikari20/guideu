# ============================================================================
# GuideU monorepo — root .gitignore
# Per-service .gitignore files (services/*, apps/*) add tool-specific rules.
# ============================================================================

# ---- Python ----------------------------------------------------------------
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
.eggs/
build/
dist/
wheels/
.venv/
venv/
env/
.mypy_cache/
.ruff_cache/
.pytest_cache/
.coverage
htmlcov/
coverage.xml

# ---- ML / model artifacts --------------------------------------------------
mlruns/
mlartifacts/
*.joblib
*.pkl
*.h5
*.pt
*.onnx

# ---- Node / TypeScript -----------------------------------------------------
node_modules/
.next/
out/
*.tsbuildinfo
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# ---- Flutter / Dart --------------------------------------------------------
.dart_tool/
.flutter-plugins
.flutter-plugins-dependencies
.pub-cache/
.pub/
**/build/
*.iml

# ---- Local databases -------------------------------------------------------
*.sqlite3
*.sqlite3-journal
*.db

# ---- Datasets (kept out of git; only directory placeholders tracked) -------
data/raw/*
!data/raw/.gitkeep
data/processed/*
!data/processed/.gitkeep
data/synthetic/*
!data/synthetic/.gitkeep

# ---- Secrets / environment -------------------------------------------------
.env
.env.*
!.env.example
!.env.sample
*.pem
*-service-account.json

# ---- IDE / editor ----------------------------------------------------------
.vscode/*
!.vscode/extensions.json
.idea/
*.swp
*.swo

# ---- OS --------------------------------------------------------------------
.DS_Store
Thumbs.db
desktop.ini
