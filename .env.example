# =============================================================================
# GuideU — Unified Environment Template
# -----------------------------------------------------------------------------
# Copy to `.env` at the repo root (`cp .env.example .env`). Docker Compose and
# every service read from this single file so configuration stays consistent
# across the polyglot stack. NEVER commit a real `.env`.
# =============================================================================

# ---- Global ----------------------------------------------------------------
COMPOSE_PROJECT_NAME=guideu
ENVIRONMENT=development                      # development | staging | production

# ---- PostgreSQL (core-engine source of truth) ------------------------------
POSTGRES_DB=guideu
POSTGRES_USER=guideu
POSTGRES_PASSWORD=change-me-postgres
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

# ---- MongoDB (analytics-engine flexible documents) -------------------------
MONGO_INITDB_ROOT_USERNAME=guideu
MONGO_INITDB_ROOT_PASSWORD=change-me-mongo
MONGO_HOST=mongo
MONGO_PORT=27017
MONGO_DB=guideu_analytics

# ---- Redis (broker / cache / pub-sub) --------------------------------------
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_URL=redis://redis:6379/0

# ---- Django core-engine ----------------------------------------------------
DJANGO_SETTINGS_MODULE=config.settings.dev
DJANGO_SECRET_KEY=change-me-with-a-50-char-random-secret
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,core-engine
DJANGO_DB_ENGINE=django.db.backends.postgresql
DJANGO_TIME_ZONE=Asia/Kathmandu
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8081
JWT_ACCESS_MINUTES=60
JWT_REFRESH_DAYS=7
# URL the core-engine uses to call the ML service for synchronous scoring
ANALYTICS_ENGINE_URL=http://analytics-engine:8001

# ---- Celery ----------------------------------------------------------------
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2

# ---- analytics-engine (FastAPI / ML) ---------------------------------------
ANALYTICS_HOST=0.0.0.0
ANALYTICS_PORT=8001
ANALYTICS_API_KEY=change-me-internal-service-token
# Path (inside the container) to the synthetic dataset package
GUIDEU_DATASET_DIR=/data/travel-planning
MLFLOW_TRACKING_URI=file:///app/mlruns
MODEL_ARTIFACT_DIR=/app/artifacts

# ---- real-time-engine (Node / Socket.IO) -----------------------------------
REALTIME_PORT=8002
# Shared HMAC secret so the realtime engine can mint/verify socket auth tokens
# issued against the same JWT signing key as Django (set equal to DJANGO_SECRET_KEY).
REALTIME_JWT_SECRET=change-me-with-a-50-char-random-secret
REALTIME_CORS_ORIGIN=http://localhost:3000,http://localhost:8081

# ---- Payment gateways (sandbox) --------------------------------------------
ESEWA_MERCHANT_CODE=EPAYTEST
ESEWA_SECRET_KEY=8gBm/:&EnhH.1/q
ESEWA_BASE_URL=https://rc-epay.esewa.com.np
KHALTI_SECRET_KEY=test_secret_key_xxxxxxxxxxxxxxxx
KHALTI_BASE_URL=https://dev.khalti.com

# ---- Third-party -----------------------------------------------------------
GOOGLE_MAPS_API_KEY=replace-with-your-key

# ---- Gateway / MLflow (docker-compose) -------------------------------------
NGINX_HTTP_PORT=80
MLFLOW_PORT=5000
